<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ClazzMapper">

    <select id="list" resultType="com.example.pojo.Clazz">
        select c.*, e.name masterName
        from clazz c
        left join emp e
        on c.master_id = e.id
        <where>
            <if test="name != null and name != ''">
                c.name like concat('%',#{name},'%')
            </if>
            <if test="begin != null and end != null">
                and c.end_date between #{begin} and #{end}
            </if>
        </where>
        order by c.update_time desc
    </select>

    <!-- 查询所有班级 -->
    <select id="listAll" resultType="com.example.pojo.Clazz">
        select id, name from clazz order by id
    </select>


</mapper>